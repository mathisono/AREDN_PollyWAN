#!/bin/sh
#
# Part of AREDN® -- Used for creating Amateur Radio Emergency Data Networks
# Copyright (C) 2026 AREDN contributors
# See Contributors file for additional contributors
#
# This program is free software: you can redistribute it and/or modify
# it under the terms of the GNU General Public License version 3.
#
# Calibration starts either from the authenticated administrator UI (manual)
# or from the explicitly enabled adaptive SLA controller (automatic). The
# destination is always read from persistent AREDN configuration and is never
# accepted from the request which starts this program.

set -u

PATH=/usr/sbin:/usr/bin:/sbin:/bin
export PATH LC_ALL=C

STATE_DIR=/tmp/wan-calibration
LOCK_DIR="$STATE_DIR/.lock"
INTERFACE="${1:-}"
TRIGGER="${2:-manual}"
CONFIG_PACKAGE=aredn
CONFIG_SECTION=multiwan

mkdir -p "$STATE_DIR" || exit 1

case "$INTERFACE" in
    wan|wan2|wan3) ;;
    *) logger -t wan-calibrate "Rejected invalid interface: $INTERFACE"; exit 2 ;;
esac
case "$TRIGGER" in
    manual) ;;
    automatic)
        [ "$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.enabled" 2>/dev/null || true)" = 1 ] || exit 2
        [ "$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.selection_mode" 2>/dev/null || true)" = adaptive ] || exit 2
        ;;
    *) logger -t wan-calibrate "Rejected invalid trigger: $TRIGGER"; exit 2 ;;
esac

STATUS_FILE="$STATE_DIR/$INTERFACE.status.json"
RESULT_FILE="$STATE_DIR/$INTERFACE.result.json"
LAST_FILE="$STATE_DIR/$INTERFACE.last"

json_string()
{
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g; s/\n/\\n/g'
}

valid_ipv4()
{
    printf '%s\n' "$1" | awk -F. '
        NF != 4 { bad = 1 }
        { for (i = 1; i <= 4; i++) if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) bad = 1 }
        END { exit bad }
    '
}

valid_port()
{
    case "$1" in ''|*[!0-9]*) return 1 ;; esac
    [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

valid_calibration_host()
{
    host="$1"
    case "$host" in
        ''|.*|*.|*..*|*[!A-Za-z0-9.-]*) return 1 ;;
    esac
    [ "${#host}" -le 253 ] || return 1
    old_ifs="$IFS"
    IFS='.'
    set -- $host
    IFS="$old_ifs"
    for label in "$@"; do
        case "$label" in
            ''|-*|*-|*[!A-Za-z0-9-]*) return 1 ;;
        esac
    done
}

valid_calibration_url()
{
    url="$1"
    host="$2"
    [ "${#url}" -le 1024 ] || return 1
    case "$url" in
        *[[:space:]]*|*#*) return 1 ;;
        "https://$host/"?*) return 0 ;;
        *) return 1 ;;
    esac
}

now_epoch() { date +%s; }
now_text() { date -u +%Y-%m-%dT%H:%M:%SZ; }

write_status()
{
    status="$1"; message="$2"; stage="${3:-}"; retry_after="${4:-0}"; tmp="$STATUS_FILE.tmp.$$"
    printf '{"status":"%s","interface":"%s","trigger":"%s","message":"%s","stage":"%s","timestamp":%s,"time":"%s","retry_after":%s}\n' \
        "$(json_string "$status")" "$(json_string "$INTERFACE")" "$(json_string "$TRIGGER")" \
        "$(json_string "$message")" "$(json_string "$stage")" "$(now_epoch)" "$(now_text)" "$retry_after" > "$tmp" && mv "$tmp" "$STATUS_FILE"
}

fail()
{
    message="$1"
    logger -t wan-calibrate "$INTERFACE/$TRIGGER: $message"
    write_status error "$message"
    exit 1
}

acquire_lock()
{
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" > "$LOCK_DIR/pid"
        return 0
    fi

    oldpid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    case "$oldpid" in
        ''|*[!0-9]*) ;;
        *) kill -0 "$oldpid" 2>/dev/null && return 1 ;;
    esac
    rm -rf "$LOCK_DIR"
    mkdir "$LOCK_DIR" 2>/dev/null || return 1
    printf '%s\n' "$$" > "$LOCK_DIR/pid"
}

if ! acquire_lock; then
    write_status busy "Another link calibration is already running"
    exit 3
fi
trap 'rm -rf "$LOCK_DIR"' EXIT HUP INT TERM

CDN_PROVIDER="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.calibration_provider" 2>/dev/null || true)"
CDN_HOST="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.calibration_host" 2>/dev/null || true)"
CDN_URL="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.calibration_url" 2>/dev/null || true)"
COOLDOWN="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.calibration_cooldown" 2>/dev/null || true)"
[ -n "$CDN_PROVIDER" ] || CDN_PROVIDER="User-selected HTTPS calibration object"
case "$COOLDOWN" in ''|*[!0-9]*) COOLDOWN=300 ;; esac
[ "$COOLDOWN" -lt 30 ] && COOLDOWN=30
valid_calibration_host "$CDN_HOST" || fail "A valid HTTPS calibration object has not been configured"
valid_calibration_url "$CDN_URL" "$CDN_HOST" || fail "The saved calibration URL is invalid or does not match its saved host"

LAST=0
if [ -r "$LAST_FILE" ]; then read -r LAST < "$LAST_FILE" || LAST=0; fi
case "$LAST" in ''|*[!0-9]*) LAST=0 ;; esac
NOW="$(now_epoch)"
ELAPSED_SINCE_LAST=$((NOW - LAST))
if [ "$ELAPSED_SINCE_LAST" -lt "$COOLDOWN" ]; then
    RETRY_AFTER=$((COOLDOWN - ELAPSED_SINCE_LAST))
    write_status cooldown "Calibration is in its cooldown period" "" "$RETRY_AFTER"
    exit 4
fi

IFACE_JSON="$(ubus call "network.interface.$INTERFACE" status 2>/dev/null)" || fail "Interface is not configured"
UP="$(printf '%s' "$IFACE_JSON" | jsonfilter -e '@.up' 2>/dev/null || true)"
DEVICE="$(printf '%s' "$IFACE_JSON" | jsonfilter -e '@.l3_device' 2>/dev/null || true)"
SOURCE="$(printf '%s' "$IFACE_JSON" | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null || true)"
case "$UP" in true|1) ;; *) fail "Interface is not up" ;; esac
case "$DEVICE" in ''|*[!A-Za-z0-9_.:-]*) fail "Interface has no usable layer-3 device" ;; esac
valid_ipv4 "$SOURCE" || fail "Interface has no usable IPv4 address"
ROUTE="$(ip -4 route show table all default dev "$DEVICE" 2>/dev/null | head -n 1 || true)"
GATEWAY="$(printf '%s\n' "$ROUTE" | sed -n 's/.* via \([^ ]*\).*/\1/p')"
valid_ipv4 "$GATEWAY" || GATEWAY="-"

PROXY_ENABLED=0
PROXY_HOST=""
PROXY_PORT=""
PROXY_USER=""
PROXY_PASSWORD=""
if [ "$INTERFACE" = wan3 ] && [ "$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.wan3_proxy_enable" 2>/dev/null || true)" = 1 ]; then
    PROXY_ENABLED=1
    PROXY_HOST="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.wan3_proxy_host" 2>/dev/null || true)"
    PROXY_PORT="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.wan3_proxy_port" 2>/dev/null || true)"
    PROXY_USER="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.wan3_proxy_username" 2>/dev/null || true)"
    PROXY_PASSWORD="$(uci -c /etc/config.mesh -q get "$CONFIG_PACKAGE.$CONFIG_SECTION.wan3_proxy_password" 2>/dev/null || true)"
    [ -n "$PROXY_HOST" ] || PROXY_HOST=192.168.49.1
    [ -n "$PROXY_PORT" ] || PROXY_PORT=8000
    valid_ipv4 "$PROXY_HOST" || fail "USB WAN proxy address is invalid"
    valid_port "$PROXY_PORT" || fail "USB WAN proxy port is invalid"
fi

printf '%s\n' "$NOW" > "$LAST_FILE"
TOTAL_BYTES=0
TOTAL_SECONDS=0
SAMPLE_MBPS=0
BYTES_INTEGER=0
SAMPLE_SECONDS=0
REMOTE_IP=""

measure()
{
    BYTES_REQUESTED="$1"
    LABEL="$2"
    CURL_ERROR="$STATE_DIR/$INTERFACE.curl-error.$$"
    write_status running "Downloading a bounded sample from the configured HTTPS object" "$LABEL"

    set -- --silent --show-error --fail --proto '=https' --proto-redir '=https' --max-redirs 0 \
        --connect-timeout 5 --max-time 35 --max-filesize "$((BYTES_REQUESTED + 4096))" \
        --interface "$SOURCE" --header 'Accept-Encoding: identity' --range "0-$((BYTES_REQUESTED - 1))" \
        --output /dev/null --write-out '%{http_code}|%{size_download}|%{time_total}|%{remote_ip}'
    if [ "$PROXY_ENABLED" = 1 ]; then
        set -- "$@" --proxy "http://$PROXY_HOST:$PROXY_PORT" --noproxy ''
        [ -n "$PROXY_USER" ] && set -- "$@" --proxy-user "$PROXY_USER:$PROXY_PASSWORD"
    else
        # An empty explicit proxy disables HTTP(S)_PROXY inherited from the environment.
        set -- "$@" --proxy ''
    fi

    OUTPUT="$(curl "$@" "$CDN_URL" 2>"$CURL_ERROR")"
    CURL_RC=$?
    if [ "$CURL_RC" -ne 0 ]; then
        logger -t wan-calibrate "$INTERFACE/$TRIGGER curl failure: $(tr '\n' ' ' < "$CURL_ERROR" | cut -c1-160)"
        rm -f "$CURL_ERROR"
        fail "Calibration object sample download failed"
    fi
    rm -f "$CURL_ERROR"

    OLD_IFS="$IFS"; IFS='|'; set -- $OUTPUT; IFS="$OLD_IFS"
    HTTP_CODE="${1:-}"
    BYTES_RECEIVED="${2:-0}"
    SAMPLE_SECONDS="${3:-0}"
    REMOTE_IP="${4:-}"
    BYTES_INTEGER="${BYTES_RECEIVED%%.*}"

    [ "$HTTP_CODE" = 206 ] || fail "Calibration object did not honor the byte-range request"
    case "$BYTES_INTEGER" in ''|*[!0-9]*) fail "Calibration object returned an invalid byte count" ;; esac
    [ "$BYTES_INTEGER" -eq "$BYTES_REQUESTED" ] || fail "Calibration object returned an incomplete sample"
    case "$REMOTE_IP" in ''|*[!0-9a-fA-F:.]*) fail "Calibration object returned an invalid remote address" ;; esac
    SAMPLE_MBPS="$(awk -v bytes="$BYTES_RECEIVED" -v seconds="$SAMPLE_SECONDS" 'BEGIN { if (seconds <= 0) exit 1; printf "%.2f", (bytes * 8.0) / seconds / 1000000.0 }')" || fail "Could not calculate calibration throughput"
    TOTAL_BYTES=$((TOTAL_BYTES + BYTES_INTEGER))
    TOTAL_SECONDS="$(awk -v total="$TOTAL_SECONDS" -v sample="$SAMPLE_SECONDS" 'BEGIN { printf "%.3f", total + sample }')" || fail "Could not account for calibration duration"
}

measure 1048576 "1 MiB"
if awk -v value="$SAMPLE_MBPS" 'BEGIN { exit !(value >= 4.0) }'; then measure 8388608 "8 MiB"; fi
if awk -v value="$SAMPLE_MBPS" 'BEGIN { exit !(value >= 25.0) }'; then measure 33554432 "32 MiB"; fi
BIN="$(awk -v value="$SAMPLE_MBPS" 'BEGIN { if (value <= 5.0) print "low"; else if (value <= 30.0) print "medium"; else print "fast" }')"

RESULT_TMP="$RESULT_FILE.tmp.$$"
TIMESTAMP="$(now_epoch)"
TIME_TEXT="$(now_text)"
printf '{"status":"complete","interface":"%s","trigger":"%s","device":"%s","source":"%s","gateway":"%s","timestamp":%s,"time":"%s","bytes":%s,"sample_bytes":%s,"seconds":%s,"sample_seconds":%s,"mbps":%s,"bin":"%s","remote_ip":"%s","cdn_host":"%s","provider":"%s","proxy_enabled":%s,"proxy_host":"%s"}\n' \
    "$(json_string "$INTERFACE")" "$(json_string "$TRIGGER")" "$(json_string "$DEVICE")" "$(json_string "$SOURCE")" "$(json_string "$GATEWAY")" \
    "$TIMESTAMP" "$TIME_TEXT" "$TOTAL_BYTES" "$BYTES_INTEGER" "$TOTAL_SECONDS" "$SAMPLE_SECONDS" "$SAMPLE_MBPS" "$BIN" \
    "$(json_string "$REMOTE_IP")" "$(json_string "$CDN_HOST")" "$(json_string "$CDN_PROVIDER")" "$PROXY_ENABLED" "$(json_string "$PROXY_HOST")" > "$RESULT_TMP" || fail "Could not write calibration result"
mv "$RESULT_TMP" "$RESULT_FILE" || fail "Could not publish calibration result"
STATUS_TMP="$STATUS_FILE.tmp.$$"
cp "$RESULT_FILE" "$STATUS_TMP" && mv "$STATUS_TMP" "$STATUS_FILE" || fail "Could not publish calibration status"
logger -t wan-calibrate "$INTERFACE/$TRIGGER: $SAMPLE_MBPS Mbit/s ($BIN), $TOTAL_BYTES bytes from $CDN_HOST"
exit 0
