#!/bin/sh
# Seed PollyWAN defaults. This script intentionally does not read or write GPS,
# gpsd, USB power, AREDN time, or location settings.

UCI='uci -c /etc/config.mesh'

if ! $UCI -q get aredn.multiwan >/dev/null 2>&1; then
    $UCI set aredn.multiwan='multiwan'
fi

set_default()
{
    option="$1"; value="$2"
    $UCI -q get "aredn.multiwan.$option" >/dev/null 2>&1 || $UCI set "aredn.multiwan.$option=$value"
}

set_default enabled 0
set_default selection_mode manual
set_default active wan
set_default active_bin unknown
set_default preferred_wan wan
set_default wan_enable 1
set_default wan2_enable 0
set_default wan3_enable 0
set_default selection_min_bin low
set_default mesh_share_min_bin medium
set_default health_interval 30
set_default health_url 'https://connectivitycheck.gstatic.com/generate_204'
set_default health_expected_codes 204
set_default failure_count 2
set_default promote_count 2
set_default hold_down 120
set_default result_ttl 28800
set_default speed_result_ttl 21600
set_default speed_test_auto 0
set_default speed_test_interval 21600
set_default speed_test_payload 5000000
set_default speed_test_method cloudflare
set_default speed_node ''
set_default speed_iperf_port 5201
set_default speed_iperf_duration 10
set_default speed_threshold_low 5
set_default speed_threshold_fast 30
set_default return_to_preferred 0
set_default calibration_interval 21600

# Ethernet role management is a second explicit opt-in. WAN3 is fixed to USB.
set_default port_roles_enabled 0
set_default port_rollback_timeout 180
set_default port1_role wan
set_default port2_role lan
set_default port3_role lan
set_default port4_role lan
set_default port5_role off
set_default port1_dtd 0
set_default port2_dtd 0
set_default port3_dtd 0
set_default port4_dtd 0
set_default port5_dtd 1

set_default wan3_device auto
set_default wan3_proxy_enable 1
set_default wan3_proxy_host 192.168.49.1
set_default wan3_proxy_port 8000
set_default wan3_proxy_username ''
set_default wan3_proxy_password ''
set_default wan3_proxy_local_port 12346

# Present only Manual and Automatic while preserving old values on upgrade.
case "$($UCI -q get aredn.multiwan.selection_mode 2>/dev/null)" in
    availability|adaptive) $UCI set aredn.multiwan.selection_mode='automatic' ;;
esac

# Migrate known development defaults without changing custom values.
if [ "$($UCI -q get aredn.multiwan.wan3_proxy_local_port 2>/dev/null)" = 12345 ]; then
    $UCI set aredn.multiwan.wan3_proxy_local_port='12346'
fi

$UCI commit aredn
exit 0
